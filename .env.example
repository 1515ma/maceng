# URL pública do site (obrigatória em produção, opcional em dev).
# Usada pelo /api/auth/password-reset para montar o redirectTo do email.
# Deve estar na allowlist do Supabase → Authentication → URL Configuration → Redirect URLs.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase — obtenha em https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-aqui

# Supabase Service Role — APENAS server-side, NUNCA expor no client
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-aqui
